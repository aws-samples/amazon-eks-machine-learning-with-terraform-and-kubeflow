{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoDBMemledger",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:BatchGetItem",
        "dynamodb:BatchWriteItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:DescribeTable",
        "dynamodb:CreateTable"
      ],
      "Resource": [
        "arn:aws:dynamodb:<REGION>:<ACCOUNT-ID>:table/memledger-memory",
        "arn:aws:dynamodb:<REGION>:<ACCOUNT-ID>:table/memledger-memory/index/*"
      ]
    },
    {
      "Sid": "OpenSearchMemledger",
      "Effect": "Allow",
      "Action": [
        "es:ESHttpGet",
        "es:ESHttpPost",
        "es:ESHttpPut",
        "es:ESHttpDelete",
        "es:ESHttpHead"
      ],
      "Resource": "arn:aws:es:<REGION>:<ACCOUNT-ID>:domain/memledger-dev/*"
    },
    {
      "Sid": "AuroraIAMAuth",
      "Effect": "Allow",
      "Action": ["rds-db:connect"],
      "Resource": "arn:aws:rds-db:<REGION>:<ACCOUNT-ID>:dbuser:<DB-RESOURCE-ID>/memledger"
    }
  ]
}
