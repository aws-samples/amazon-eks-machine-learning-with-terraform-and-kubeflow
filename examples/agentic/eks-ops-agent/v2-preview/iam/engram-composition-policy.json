{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoDBEngram",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:BatchGetItem",
        "dynamodb:BatchWriteItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:DescribeTable",
        "dynamodb:CreateTable"
      ],
      "Resource": [
        "arn:aws:dynamodb:REGION:ACCOUNT_ID:table/engram-memory",
        "arn:aws:dynamodb:REGION:ACCOUNT_ID:table/engram-memory/index/*"
      ]
    },
    {
      "Sid": "OpenSearchEngram",
      "Effect": "Allow",
      "Action": [
        "es:ESHttpGet",
        "es:ESHttpPost",
        "es:ESHttpPut",
        "es:ESHttpDelete",
        "es:ESHttpHead"
      ],
      "Resource": "arn:aws:es:REGION:ACCOUNT_ID:domain/engram-dev/*"
    }
  ]
}
